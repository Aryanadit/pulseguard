{
  "name": "@pulseguard/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate --schema=prisma/schema.prisma && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
